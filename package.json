{
  "name": "kite",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build && npm run build:check-console",
    "preview": "vite preview",
    "tauri": "tauri",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "check-deps": "node ./scripts/check-deps.mjs",
    "check-deps:cve": "node ./scripts/check-deps.mjs --cve",
    "check-csp": "node ./scripts/check-csp.mjs",
    "check-contract": "node ./scripts/check-contract.mjs",
    "check-contrast": "node ./scripts/check-contrast.mjs",
    "build:check-console": "node ./scripts/check-console-drop.mjs",
    "check-tw-purge": "node ./scripts/check-tw-purge.mjs",
    "check-perf-budget": "node ./scripts/check-perf-budget.mjs",
    "check-bundle-config": "node ./scripts/check-bundle-config.mjs",
    "check-i18n-hardcode": "node ./scripts/check-i18n-hardcode.mjs",
    "check-manual-chunks": "node ./scripts/check-manual-chunks.mjs",
    "append-release-notes": "node ./scripts/append-release-notes.mjs",
    "measure-cold-start": "node ./scripts/measure-cold-start.mjs",
    "test": "vitest run"
  },
  "dependencies": {
    "dompurify": "^3.4.11",
    "i18next": "^23.16.8",
    "katex": "^0.17.0",
    "mermaid": "^11.16.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-i18next": "^15.7.4",
    "react-markdown": "^9.0.0",
    "rehype-highlight": "^7.0.0",
    "rehype-katex": "^7.0.1",
    "rehype-mermaid": "^3.0.0",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/cli": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.0.0",
    "@tauri-apps/plugin-fs": "^2.0.0",
    "@tauri-apps/plugin-store": "^2.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/dompurify": "^3.0.5",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^9.0.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "terser": "^5.48.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.9"
  }
}
